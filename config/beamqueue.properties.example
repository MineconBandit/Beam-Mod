# Beam Queue – AI reply config (g4f.dev)
# Copy to <game-dir>/config/beamqueue.properties and set your key.
# Or set env BEAMQUEUE_API_KEY or BEAMQUEUE_OPENAI_API_KEY.

# g4f API endpoint used by default in code.
api_url=https://g4f.space/api/ollama/chat/completions
api_key=your-g4f-api-key-here
# Default model in code is empty (provider auto-select). Optional:
# model=

# Debug: set to true for verbose logs (prefix matching, tick phase, scan, AI) in latest.log
# Or set env BEAMQUEUE_DEBUG=true
# debug=true
